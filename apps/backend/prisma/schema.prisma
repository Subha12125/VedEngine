generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Document {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SearchLog {
  id        String   @id @default(uuid())
  query     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
